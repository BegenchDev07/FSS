---
import { markdownify } from "@/lib/utils/textConverter";

type Props = {
  content: {
    enable?: boolean;
    label?: string;
    url?: string;
    hoverEffect?: string;
    variant?: string;
    icon?: string;
    rel?: string;
    target?: string;
    tag?: string;
  };
  class?: string;
};

const { content, class: additionalClasses = "" } = Astro.props;
const {
  enable = true,
  label = "Button",
  url = "#",
  hoverEffect = "",
  variant = "fill",
  icon = "",
  rel = "",
  target = "",
  tag = "a"
} = content;

if (!enable) {
  return null;
}

// Base button classes
const baseClasses = "inline-flex items-center justify-center gap-2 rounded-lg px-6 py-3 text-sm font-medium transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed";

// Variant classes
const variantClasses = {
  fill: "bg-primary text-primary-foreground hover:bg-primary/90 focus:ring-primary",
  outline: "border-2 border-primary text-primary bg-transparent hover:bg-primary hover:text-primary-foreground focus:ring-primary",
  text: "text-primary bg-transparent hover:bg-primary/10 focus:ring-primary",
  circle: "rounded-full bg-primary text-primary-foreground hover:bg-primary/90 focus:ring-primary",
};

// Hover effect classes
const hoverEffectClasses = {
  "text-flip": "group relative overflow-hidden",
  "creative-fill": "group relative overflow-hidden before:absolute before:inset-0 before:bg-primary before:scale-x-0 before:origin-left before:transition-transform before:duration-300 hover:before:scale-x-100",
  "magnetic": "group transition-transform hover:scale-105",
  "magnetic-text-flip": "group relative overflow-hidden transition-transform hover:scale-105",
};

// Combine classes
const buttonClasses = [
  baseClasses,
  variantClasses[variant as keyof typeof variantClasses] || variantClasses.fill,
  hoverEffectClasses[hoverEffect as keyof typeof hoverEffectClasses] || "",
  additionalClasses
].filter(Boolean).join(" ");

// Determine element attributes
const commonAttributes = {
  class: buttonClasses,
  ...(rel && { rel }),
  ...(target && { target }),
};

// Icon rendering
const iconSvg = icon ? `<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><use href="#${icon}"></use></svg>` : "";
---

{tag === "button" ? (
  <button {...commonAttributes} type="button">
    {hoverEffect === "text-flip" || hoverEffect === "magnetic-text-flip" ? (
      <span class="group-hover:-translate-y-full transition-transform duration-300">
        <Fragment set:html={iconSvg} />
        <span set:html={markdownify(label)} />
      </span>
      <span class="absolute inset-0 flex items-center justify-center translate-y-full group-hover:translate-y-0 transition-transform duration-300">
        <Fragment set:html={iconSvg} />
        <span set:html={markdownify(label)} />
      </span>
    ) : hoverEffect === "creative-fill" ? (
      <span class="relative z-10">
        <Fragment set:html={iconSvg} />
        <span set:html={markdownify(label)} />
      </span>
    ) : (
      <>
        <Fragment set:html={iconSvg} />
        <span set:html={markdownify(label)} />
      </>
    )}
  </button>
) : (
  <a href={url} {...commonAttributes}>
    {hoverEffect === "text-flip" || hoverEffect === "magnetic-text-flip" ? (
      <span class="group-hover:-translate-y-full transition-transform duration-300">
        <Fragment set:html={iconSvg} />
        <span set:html={markdownify(label)} />
      </span>
      <span class="absolute inset-0 flex items-center justify-center translate-y-full group-hover:translate-y-0 transition-transform duration-300">
        <Fragment set:html={iconSvg} />
        <span set:html={markdownify(label)} />
      </span>
    ) : hoverEffect === "creative-fill" ? (
      <span class="relative z-10">
        <Fragment set:html={iconSvg} />
        <span set:html={markdownify(label)} />
      </span>
    ) : (
      <>
        <Fragment set:html={iconSvg} />
        <span set:html={markdownify(label)} />
      </>
    )}
  </a>
)}

<style>
  /* Additional styles for creative effects */
  .group:hover .creative-fill::before {
    transform: scaleX(1);
  }

  /* Text flip effect positioning */
  .group .text-flip {
    position: relative;
    overflow: hidden;
  }
</style>
